graph TD
    User([Запрос: INSERT/UPDATE]) --> Parser[1. Синтаксический парсер]
    
    subgraph "Relational Engine (Обработка запроса)"
        Parser --> Algebrizer["<b>2. Algebrizer & Binding</b><br/>Сопоставляет запрос с метаданными:<br/>существуют ли таблицы и верны ли типы данных."]
        Algebrizer --> Optimizer["<b>3. Query Optimizer</b><br/>Строит план выполнения, вшивая в него<br/>логику проверок CHECK и Foreign Keys."]
    end

    subgraph "Storage Engine (Работа с памятью)"
        Optimizer --> Latch["<b>4. Latch Lock</b><br/>Защелка в памяти: гарантирует, что<br/>пока идет валидация, байты никто не изменит."]
        Latch --> TypeCheck["<b>5. Байтовый Парсинг</b><br/>Валидация на уровне байтов: корректна ли<br/>структура данных (напр. дата/время)."]
        TypeCheck --> LogicCheck["<b>6. Constraint Engine</b><br/>Проверка бизнес-правил: больше ли цена нуля,<br/>уникален ли Email и т.д."]
        
        LogicCheck -- "Валидация OK" --> LogReserve["<b>7. Log Manager: WAL</b><br/>Гарантия атомарности: запись операции в лог<br/>перед изменением самой страницы."]
        LogReserve --> DirtyPage["<b>8. Модификация страницы</b><br/>Данные меняются в RAM. Страница помечается<br/>как 'грязная' (отличается от диска)."]
    end

    subgraph "Фиксация (Синхронно)"
        DirtyPage --> Commit["<b>9. COMMIT</b><br/>Сброс лога транзакций на диск.<br/>Данные теперь невозможно потерять."]
        Commit --> Ack([Ответ пользователю: УСПЕХ])
    end

    subgraph "Фоновые процессы (Асинхронно)"
        DirtyPage -.-> Checkpoint["<b>10. Checkpoint / Lazy Writer</b><br/>Фоновый перенос измененных страниц<br/>из памяти на физический диск."]
        Checkpoint --> CalcChecksum["<b>11. Расчет Checksum</b><br/>Валидация физики: создание отпечатка<br/>страницы для защиты от повреждения железа."]
        CalcChecksum --> Disk[(<b>12. Физический Диск</b><br/>Конечное хранилище валидных байтов.)]
    end
    
    LogicCheck -- "ОШИБКА" --> Rollback["<b>ROLLBACK</b><br/>Отмена всех действий. База возвращается<br/>в состояние до начала запроса."]
